# macOS Finder metadata
.DS_Store

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
mxlrc-go
/canticle

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out
coverage.html

# Dependency directories (remove the comment below to include it)
# vendor/

# Build artifacts
dist/

# Generated web UI assets (issue #364): produced on build by `make ui`, never
# committed. web/static/embed.go embeds output.css at compile time, so run
# `make ui` after a fresh clone before `go build`.
web/templates/*_templ.go
web/static/css/output.css

# GoReleaser before-hook tooling (downloaded Tailwind standalone CLI)
/.tools/

# Docs build output
/site/

# Playwright MCP rendered-evidence artifacts (local UI UAT only)
.playwright-mcp/
/m55-ref-*.png
/mx-210-*.png

# Failed lyrics fetch logs
*_failed.txt

# Local token config
.env
profile.env

# Superpowers plans (local-only)
docs/superpowers/

# Design docs (local working notes; already-tracked docs stay tracked)
docs/design/

# Serena MCP
.serena/

# AI assistant config (local only — except shared release metadata)
.claude/*
!.claude/release.toml
.opencode/get-shit-done/
.opencode/node_modules/
.opencode/settings.json
