root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Go: tabs (enforced by gofmt)
[*.go]
indent_style = tab
indent_size = 4

# Config files: 2-space indent
[*.{json,yaml,yml,toml,md}]
indent_style = space
indent_size = 2

# Makefile: must use tabs
[Makefile]
indent_style = tab
